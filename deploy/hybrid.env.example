# Recommended: one deploy, public demo + family full access (see docs/DEPLOYMENT.md)
# Copy to deploy/hybrid.env and fill in secrets.
#
# Docker build (hybrid): VITE_DEMO_MODE=1 is the Dockerfile default — baked into the SPA so a
# brief /api/config failure still shows the public demo instead of the access gate.
# Personal-only image: docker build --build-arg VITE_DEMO_MODE=0 .
# Never pass VITE_API_ACCESS_KEY at image build time — family use ?access=YOUR_API_ACCESS_KEY .

ENVIRONMENT=production
DEMO_MODE=1
PRESEED_DEMO_RULEBOOK=1
OCR_FALLBACK=1
DATA_DIR=/data

ANTHROPIC_API_KEY=
API_ACCESS_KEY=
CORS_ORIGINS=https://your-app.fly.dev

RATE_LIMIT_ENABLED=1
RATE_LIMIT_LLM_MAX=15
RATE_LIMIT_EXPENSIVE_MAX=5
RETRIEVAL_TELEMETRY=0
RULING_FEEDBACK=0

# README link (recruiters):  https://your-app.fly.dev
# Family bookmark (private): https://your-app.fly.dev/?access=YOUR_API_ACCESS_KEY
