# Alternative: demo-only deploy (no family cloud access). Recommended: deploy/hybrid.env.example
# See docs/DEPLOYMENT.md

ENVIRONMENT=production
DEMO_MODE=1
PRESEED_DEMO_RULEBOOK=1
OCR_FALLBACK=1

ANTHROPIC_API_KEY=
CORS_ORIGINS=https://your-demo-app.onrender.com

# Leave API_ACCESS_KEY unset for a public demo.

RATE_LIMIT_ENABLED=1
RATE_LIMIT_LLM_MAX=15
RATE_LIMIT_EXPENSIVE_MAX=5
RETRIEVAL_TELEMETRY=0
RULING_FEEDBACK=0
