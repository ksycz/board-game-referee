# Alternative: personal-only deploy (no public demo). Recommended: deploy/hybrid.env.example
# See docs/DEPLOYMENT.md
#
# Docker build: docker build --build-arg VITE_DEMO_MODE=0 .

ENVIRONMENT=production
DEMO_MODE=0
PRESEED_DEMO_RULEBOOK=0
OCR_FALLBACK=1

ANTHROPIC_API_KEY=
API_ACCESS_KEY=
CORS_ORIGINS=https://your-private-app.fly.dev

RATE_LIMIT_ENABLED=1
RETRIEVAL_TELEMETRY=0
RULING_FEEDBACK=0

# Share with invited users:
# https://your-private-app.fly.dev/?access=YOUR_API_ACCESS_KEY
